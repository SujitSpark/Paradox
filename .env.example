# Paradox (JudicAI) Environment Configuration Template

# Database Configuration
# For local development, use SQLite: sqlite:///./judic_ai.db
# For production, use a PostgreSQL URL (e.g., Railway, Supabase)
DATABASE_URL=your_database_url_here

# Security & Authentication
# Generate a secure secret key using: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: Agent Configurations
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
